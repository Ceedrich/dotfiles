#!/usr/bin/env bash

shopt -s extglob

fatal () {
  echo "FATAL:" "$@" >&2
  exit 1
}

IMAGE_EXTENSIONS=(png gif jpg jpeg webp bmp svg)
VIDEO_EXTENSIONS=(webm mkv vob gifv avi mov mp4 mpg mpeg mpv)

image_pat=$(IFS='|'; echo "@(${IMAGE_EXTENSIONS[*]})")
video_pat=$(IFS='|'; echo "@(${VIDEO_EXTENSIONS[*]})")
add_icons() {
  local icon_str ext display_str;
  while read -r -d $'\0' file; do
    ext="${file##*.}"
    case "$ext" in
      pdf) icon_str="application-pdf";;
      $image_pat) icon_str="image";;
      $video_pat) icon_str="video";;
      doc|docx|odt) icon_str="application-vnd.oasis.opendocument.text";;
      md|markdown) icon_str="text-markdown";;
      txt) icon_str="text" ;;
      toml) icon_str="application-toml" ;;
      yaml) icon_str="application-json" ;;
      html) icon_str="text-html" ;;
      htm) icon_str="text-html" ;;
      xml) icon_str="text-xml" ;;
      mp3|ogg|wav) icon_str="audio-mp3" ;;
      zip) icon_str="application-zip";;
      *) icon_str="gtk-file";;
    esac
    $FOLDERS && icon_str="folder"
    display_str="${file#"$PREFIX"}"
    echo -e "$file\0icon\x1f$icon_str\x1fdisplay\x1f$display_str"
  done
}

usage() {
  cat << EOF
usage: $0 [options]

Options:
  -h    Show this message and exit
  -e    Comma separted list of extensions to search for
  -f    Search for folders instead of files, ignores '-e'
  -d    Set the search directory (default '\$HOME/')
  -s    Strip the given prefix, defaults to search directory set by '-d'
  -p    Set prompt for rofi
  -v    Find videos, shorthand for '-e $(IFS=", "; echo "${VIDEO_EXTENSIONS[*]}")'
  -i    Find images, shorthand for '-e $(IFS=", "; echo "${IMAGE_EXTENSIONS[*]}")'
EOF
}

SEARCH_DIR=
PROMPT=
PREFIX=
FOLDERS=false;

while getopts "hfd:t:e:p:s:iv" opt; do
  case $opt in
    h) usage; exit ;;
    e) IFS=, read -ra EXTENSIONS <<< "$OPTARG" ;;
    f) FOLDERS=true;;
    d) SEARCH_DIR=$OPTARG ;;
    p) PROMPT=$OPTARG ;;
    s) PREFIX=$OPTARG ;;
    i) EXTENSIONS=( "${IMAGE_EXTENSIONS[@]}" );;
    v) EXTENSIONS=( "${VIDEO_EXTENSIONS[@]}" );;
    *) usage; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

[[ -z $SEARCH_DIR ]] && SEARCH_DIR="$HOME/"
[[ -z $PROMPT ]] && PROMPT="Open Files"
[[ -z $PREFIX ]] && PREFIX=$SEARCH_DIR
[[ -z $TYPE ]] && TYPE="f"

args=()
if $FOLDERS; then
  args=("--type=directory")
else
  args=(
    "--type=file"
    "--type=symlink"
    "${EXTENSIONS[@]/#/--extension=}"
  )
fi

fd '.' "${args[@]}" "$SEARCH_DIR" --print0 \
  | add_icons \
  | rofi -show-icons -dmenu -i -format "q" -p "$PROMPT" \
  | xargs handlr open >/dev/null 2>&1 & disown

