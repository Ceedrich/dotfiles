#!/usr/bin/env bash

set -o pipefail

PROGRAM_NAME=$(basename "$0")
REPO=$HOME/dotfiles

RST=$'\e[0m'
BOLD=$'\e[1m'
RED=$'\e[31m'
GREEN=$'\e[32m'
MAGENTA=$'\e[35m'

main() {
  case "$1" in 
    rebuild) shift 1; rebuild "$@";;
    build) shift 1; build "$@";;
    rollback) shift 1; rollback "$@";;
    *) usage; exit 1 ;;
  esac
}

usage() {
  cat << EOF
usage: $PROGRAM_NAME <command>

${BOLD}COMMANDS${RST}:

${BOLD}${MAGENTA}build${RST}: $PROGRAM_NAME build [nixos-rebuild options]

${BOLD}${MAGENTA}rollback${RST}: $PROGRAM_NAME rollback [nixos-rebuild options]

${BOLD}${MAGENTA}rebuild${RST}: $PROGRAM_NAME rebuild [nixos-rebuild options]

nixos-rebuild options: See ${MAGENTA}nixos-rebuild(8)${RST}

EOF
}

fatal() {
  fatal-noexit "$@"
  exit 1
}

fatal-noexit() {
  echo "${RED}[FATAL]${RST}" "$@" >&2
}

info() {
  echo "${GREEN}[INFO]${RST}" "$@" >&2
}

build() {
  pushd "$REPO" || fatal "Changing direcotry failed"
  trap popd EXIT

  nixos-rebuild build --flake . "$@"
}

rollback() {
  local current last
  pushd "$REPO" || fatal "Changing direcotry failed"
  trap popd EXIT

  read -r current last <<< "$(parse_generations)"

  nixos-rebuild --rollback --flake . "$@"
}

rebuild() {
  local current_branch host_branch gen worktree_dir

  pushd "$REPO" || fatal "Changing direcotry failed"
  trap 'popd' EXIT 

  host_branch="host/$(hostname)"
  current_branch="$(git branch --show-current)"

  [[ $current_branch =~ ^host\/[a-zA-Z]+$ ]] && fatal "You must not make changes on a host branch!"

  info "Fromatting..."
  format || fatal "Fromatting failed"

  [[ -z "$(git diff --name-only)" ]] && [ -z "$(git diff --staged --name-only)" ] \
    || fatal "Commit your changes before rebuilding"

  info "Creating temporary directory for worktree"
  worktree_dir=$(mktemp -d)

  info "Changing from branch '$current_branch' to '$host_branch'"
  git show-ref --verify --quiet "refs/heads/$host_branch" || git branch "$host_branch" # Make sure branch exists
  git worktree add "$worktree_dir" "$host_branch"
  cd "$worktree_dir" || fatal "Could not change to the worktree directory"

  info "Updating '$host_branch' from '$current_branch'"
  git restore --source="$current_branch" --worktree --staged .
  git commit --allow-empty -m "Update $host_branch from $current_branch"

  info "Building nix configuration"
  nixos-rebuild switch --flake . --no-update-lock-file "$@" 2>&1 | tee nixos-switch.log >&2 || {
    cat nixos-switch.log | grep --color -C 3 -E "error|warning"
    fatal-noexit "Build failed!" $'\n'"inspect the file ${BOLD}${worktree_dir}/nixos-switch.log${RST} for further information";
    info "resetting HEAD"
    git reset --hard HEAD~ 
    exit 1
  }

  gen=$(nixos-rebuild list-generations | awk '$8 == "True" {print $1 "\t" $2 "\t" $3 "\t" $4 "\t" $5 "\t" $6 "\t" $7 }')

  git commit --amend -m "Update $host_branch from $current_branch"$'\n'"$gen"
  info "Pushing to remote repository"
  git push -u origin "$host_branch"
}

parse_generations() {
  local current last
  local generation is_current
  while read -r generation _ _ _ _ _ _ is_current; do
    [[ $generation == "Generation" ]] && continue
    if [[ -n $current ]]; then 
      last=$generation; 
      break
    fi
    [[ $is_current == "True" ]] && current=$generation
  done <<< "$(nixos-rebuild list-generations)"
  echo "$current $last"
}

format() {
  alejandra . &>/dev/null
}

main "$@"
